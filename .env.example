# ═══════════════════════════════════════════════════════════════
# Agentischer Document Store — Konfiguration
# Kopiere diese Datei zu .env und passe die Werte an
# ═══════════════════════════════════════════════════════════════
#
# cp .env.example .env
# chmod 600 .env  # wichtig: enthaelt Secrets
# ═══════════════════════════════════════════════════════════════

# ─── Datenbank ───
# Bitte VOR dem ersten Start setzen. Mindestens 16 Zeichen empfohlen.
POSTGRES_PASSWORD=<HIER-STARKES-PASSWORT-EINSETZEN>

# ─── API-Authentifizierung ───
# Ein Secret-Token fuer alle API-Calls. Leer lassen = Auth deaktiviert (nur Dev!)
DOCSTORE_API_KEY=<HIER-API-KEY-EINSETZEN>
DOCSTORE_API_KEY_REQUIRED=true

# ─── Port-Bindings ───
# Frontend: extern erreichbar (Default: alle Interfaces, Port 80)
# Backend/DB/Redis: nur localhost (127.0.0.1) fuer Sicherheit
FRONTEND_PORT=80
BACKEND_PORT=127.0.0.1:8000
POSTGRES_PORT=127.0.0.1:5432
REDIS_PORT=127.0.0.1:6379
OLLAMA_PORT=127.0.0.1:11434
QDRANT_PORT=127.0.0.1:6333

# ─── LLM-Provider ───
# Ollama intern via docker-compose profile "llm"
# Alternativ: externe Ollama-Instanz
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── LLM-Provider-API-Keys ───
# Zentrale Ablage fuer API-Keys — Endnutzer sehen die Keys NIE, nur den Provider-Namen.
# Ein Provider wird erst in der UI als "konfiguriert" (gruen) angezeigt, wenn der
# passende Key hier gesetzt ist. Self-Hosted-Provider (Ollama, vLLM, llama.cpp)
# brauchen keinen Key.

# OpenAI (https://platform.openai.com/api-keys)
# DOCSTORE_OPENAI_API_KEY=sk-proj-...

# Mistral AI (https://console.mistral.ai/api-keys/)
# DOCSTORE_MISTRAL_API_KEY=...

# Anthropic Claude (https://console.anthropic.com/settings/keys)
# DOCSTORE_ANTHROPIC_API_KEY=sk-ant-...

# Azure OpenAI — Format: "endpoint|key"
# DOCSTORE_AZURE_API_KEY=https://myresource.openai.azure.com|abc123def...

# Groq (https://console.groq.com/keys) — schnelle Inferenz via LPU
# DOCSTORE_GROQ_API_KEY=gsk_...

# Together AI (https://api.together.ai/settings/api-keys) — viele OSS-Modelle
# DOCSTORE_TOGETHER_API_KEY=...

# DeepSeek (https://platform.deepseek.com/api_keys) — guenstig, stark in Code
# DOCSTORE_DEEPSEEK_API_KEY=sk-...

# Fireworks AI (https://fireworks.ai/account/api-keys)
# DOCSTORE_FIREWORKS_API_KEY=...

# OpenRouter (https://openrouter.ai/keys) — Meta-Router zu 200+ Modellen
# DOCSTORE_OPENROUTER_API_KEY=sk-or-...

# Fuer Custom-Provider aus DOCSTORE_CUSTOM_PROVIDERS nach demselben Schema:
# DOCSTORE_{ID}_API_KEY  (ID = der "id"-Wert aus dem JSON, in Grossbuchstaben)


# ─── LLM-Provider-Endpunkte ───
# Alle diese Provider werden automatisch registriert sobald die URL gesetzt ist.
# Die Provider-Liste enthaelt sie dann immer — Verfuegbarkeit zeigt sich erst
# beim Verbindungstest oder ersten Call.

# llama.cpp Server (`llama-server -m model.gguf --port 8080`)
# DOCSTORE_LLAMACPP_URL=http://localhost:8080/v1

# mistral.rs (Rust-Inferenz, GPU + quantisierte Modelle)
# DOCSTORE_MISTRALRS_URL=http://localhost:1234/v1

# vLLM (hoher Durchsatz, Komm.ONE DGX Spark)
# DOCSTORE_VLLM_URL=http://10.20.30.40:8000/v1
# DOCSTORE_VLLM_MODEL=mistralai/Mistral-Small-24B-Instruct-2501

# LocalAI (OpenAI-Drop-in-Replacement)
# DOCSTORE_LOCALAI_URL=http://localhost:8080/v1

# Text Generation Inference (HuggingFace)
# DOCSTORE_TGI_URL=http://localhost:3000/v1

# ─── Benutzerdefinierte LLM-Provider (JSON-Liste) ───
# Registriert beliebige weitere OpenAI-kompatible Endpunkte ohne Code-Aenderung.
# Beispiel fuer einen produktiven GPU-Cluster:
# DOCSTORE_CUSTOM_PROVIDERS='[{"id":"komm1-gpu","name":"Komm.ONE GPU-Cluster","base_url":"http://gpu.intern:8000/v1","default_model":"mistral-24b","requires_key":false}]'

# ─── Storage-Limits ───
# Maximale Groesse pro Sammlung (MB)
MAX_STORE_SIZE_MB=5000
# Maximale Gesamt-Groesse aller Sammlungen (MB)
MAX_TOTAL_SIZE_MB=50000
# Datei-TTL in Tagen (0 = unbegrenzt)
FILE_TTL_DAYS=365

# ─── Rate-Limiting ───
RATE_LIMIT_PER_MINUTE=60

# ─── Logging ───
# debug | info | warning | error
LOG_LEVEL=info

# ─── Performance ───
# Anzahl Uvicorn-Worker (Empfehlung: 2 * CPU-Cores)
UVICORN_WORKERS=2

# Celery-Worker Concurrency (wenn Profile "worker" aktiv)
CELERY_CONCURRENCY=2

# Memory-Limit fuer Backend-Container
BACKEND_MEM_LIMIT=2G

# ─── Corporate Proxy (optional) ───
# Fuer Build & Runtime — Komm.ONE-Umgebung bereits vorkonfiguriert
# HTTP_PROXY=http://10.150.201.102:3128
# HTTPS_PROXY=http://10.150.201.102:3128
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,postgres,redis,ollama,qdrant

# ─── Timezone ───
TZ=Europe/Berlin

# ═══════════════════════════════════════════════════════════════
# Erweiterungen (optional)
# ═══════════════════════════════════════════════════════════════

# ─── Traefik (HTTPS + Let's Encrypt) ───
# Aktiviert mit: make up-traefik
DOCSTORE_DOMAIN=docstore.example.com
TRAEFIK_ACME_EMAIL=admin@example.com
# Dashboard-Auth: htpasswd-Format, generieren mit:
#   htpasswd -nb admin SecretPass | sed -e 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$H6uskkkW$$IgXLP6ewTrSuBkTrqE8wj/
TRAEFIK_LOG_LEVEL=INFO

# ─── Monitoring (Prometheus + Grafana) ───
# Aktiviert mit: make up-monitoring
# Default-Passwort generieren: make grafana-password
GRAFANA_ADMIN_PASSWORD=<HIER-PASSWORT-EINSETZEN>
GRAFANA_ROOT_URL=http://localhost:3000
PROMETHEUS_RETENTION=30d

# ─── GitLab-CI Proxy (nur fuer Corporate-CI) ───
# CI_HTTP_PROXY=http://proxy.intern:3128
# CI_HTTPS_PROXY=http://proxy.intern:3128
